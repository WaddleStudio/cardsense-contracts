{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cardsense.com/schemas/promotion-normalized.schema.json",
  "title": "Normalized Promotion Schema",
  "description": "Schema for normalized CardSense promotions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "promoId",
    "promoVersionId",
    "title",
    "cardCode",
    "cardName",
    "bankCode",
    "bankName",
    "category",
    "cashbackType",
    "cashbackValue",
    "minAmount",
    "frequencyLimit",
    "requiresRegistration",
    "recommendationScope",
    "validFrom",
    "validUntil",
    "conditions",
    "excludedConditions",
    "sourceUrl",
    "summary",
    "rawTextHash",
    "extractorVersion",
    "extractedAt",
    "confidence",
    "status"
  ],
  "properties": {
    "promoId": { "type": "string", "minLength": 8 },
    "promoVersionId": { "type": "string", "minLength": 16 },
    "title": { "type": "string", "minLength": 3, "maxLength": 200 },
    "cardCode": { "type": "string", "minLength": 3 },
    "cardName": { "type": "string", "minLength": 3, "maxLength": 100 },
    "cardStatus": { "type": "string", "enum": ["ACTIVE", "DISCONTINUED"] },
    "annualFee": { "type": "integer", "minimum": 0 },
    "applyUrl": { "type": ["string", "null"], "format": "uri" },
    "bankCode": {
      "type": "string",
      "enum": ["CTBC", "ESUN", "TAISHIN", "CATHAY", "MEGA", "FUBON", "FIRST", "SINOPAC", "TPBANK", "UBOT"]
    },
    "bankName": { "type": "string", "minLength": 2, "maxLength": 100 },
    "category": {
      "type": "string",
      "enum": ["DINING", "TRANSPORT", "ONLINE", "OVERSEAS", "SHOPPING", "GROCERY", "ENTERTAINMENT", "OTHER"]
    },
    "subcategory": { "type": "string", "default": "GENERAL" },
    "channel": { "type": ["string", "null"], "enum": ["ONLINE", "OFFLINE", "ALL", null] },
    "cashbackType": { "type": "string", "enum": ["PERCENT", "FIXED", "POINTS"] },
    "cashbackValue": { "type": "number", "minimum": 0.01 },
    "minAmount": { "type": "integer", "minimum": 0 },
    "maxCashback": { "type": ["integer", "null"], "minimum": 0 },
    "frequencyLimit": { "type": "string", "enum": ["MONTHLY", "QUARTERLY", "YEARLY", "ONCE", "NONE"] },
    "requiresRegistration": { "type": "boolean" },
    "recommendationScope": { "type": "string", "enum": ["RECOMMENDABLE", "CATALOG_ONLY", "FUTURE_SCOPE"] },
    "eligibilityType": { "type": ["string", "null"], "enum": ["GENERAL", "PROFESSION_SPECIFIC", "BUSINESS", null] },
    "stackability": { "$ref": "#/$defs/stackability" },
    "validFrom": { "type": "string", "format": "date" },
    "validUntil": { "type": "string", "format": "date" },
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" }
    },
    "excludedConditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" }
    },
    "sourceUrl": { "type": "string", "format": "uri" },
    "summary": { "type": "string", "minLength": 3, "maxLength": 300 },
    "rawTextHash": { "type": "string", "minLength": 32 },
    "extractorVersion": { "type": "string", "minLength": 3 },
    "extractedAt": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "status": { "type": "string", "enum": ["ACTIVE", "EXPIRED", "REVOKED"] },
    "planId": { "type": ["string", "null"], "minLength": 3 }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value", "label"],
      "properties": {
        "type": { "type": "string", "minLength": 3 },
        "value": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    },
    "stackability": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["benefitLayer", "relationshipMode", "priority", "requiresPromoVersionIds", "excludesPromoVersionIds", "stackWithPromoVersionIds"],
      "properties": {
        "benefitLayer": {
          "type": "string",
          "enum": ["BASE", "BONUS", "MILESTONE", "WELCOME", "INSTALLMENT", "MERCHANT_FUNDED", "MANUAL"]
        },
        "relationshipMode": {
          "type": "string",
          "enum": ["ALWAYS_STACKABLE", "MUTUALLY_EXCLUSIVE", "CONDITIONAL", "MANUAL_REVIEW"]
        },
        "groupId": { "type": ["string", "null"], "minLength": 3, "maxLength": 120 },
        "priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "requiresPromoVersionIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "uniqueItems": true
        },
        "excludesPromoVersionIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "uniqueItems": true
        },
        "stackWithPromoVersionIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "uniqueItems": true
        },
        "notes": { "type": ["string", "null"], "minLength": 1, "maxLength": 240 }
      }
    }
  }
}
